{
  "manifest_version": 3,
  "name": "Playwright Trace Viewer",
  "version": "0.4.0",
  "description": "在 Allure 报告中直接预览 Playwright trace 压缩包",
  "permissions": [
    "storage",
    "tabs",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "src/background/sw.ts",
    "type": "module"
  },
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Playwright Trace Viewer",
    "default_icon": {
      "16": "icon-16.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    }
  },
  "options_page": "src/options/options.html",
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/content/injector.ts"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/viewer/*",
        "vendor/trace-viewer/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
